---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getEntry } from "astro:content";
import { getPosts, formatDate } from "../lib/posts";
import { copy } from "../i18n/ui";
import { path } from "../lib/path";

const posts = (await getPosts()).filter((p) => !p.data.draft).slice(0, 5);
const me10s = await getEntry("pages", "me-10s");
if (!me10s) {
  throw new Error("Missing content: src/content/pages/me-10s.md");
}
const timeline = me10s.data.timeline ?? [];
---

<BaseLayout title="cupofluci" description="A small personal site by Luci.">
  <p class="home-note"><em>{copy.homeAiDisclaimer}</em></p>
  <h2>{me10s.data.title}</h2>
  {me10s.data.tagline ? <p>{me10s.data.tagline}</p> : null}
  {
    timeline.map((item) => (
      <p class="timeline-item">
        <span class="timeline-year">{item.year}</span>
        {` ${item.text}`}
      </p>
    ))
  }

  <h2>
    <a href={path("/about")}>{copy.homeMe10m}</a>?
  </h2>
  <p>
    See my <a href={path("/about")}>/about</a> page.
  </p>

  <h2>
    <a href={path("/now")}>{copy.homeNowBlurb}</a>?
  </h2>
  <p>
    See my <a href={path("/now")}>/now</a> page.
  </p>

  <h2>
    <a href={path("/contact")}>{copy.homeContact}</a>
  </h2>
  <p>
    I like meeting people, and I reply to every email, so{" "}
    <a href={path("/contact")}>say hello</a>.
  </p>

  <h2>
    {copy.homeNewestPrefix}<a href={path("/article")}>{copy.homeNewestArticles}</a>
  </h2>
  {
    posts.length ? (
      <ul class="list">
        {posts.map((post) => (
          <li>
            <span class="date">{formatDate(post.data.date)}</span>
            <a href={path(`/article/${post.id}`)}>{post.data.title}</a>
          </li>
        ))}
      </ul>
    ) : (
      <p class="muted">{copy.articleEmpty}</p>
    )
  }
  <p>
    {copy.homeMorePrefix}<a href={path("/article")}>{copy.homeMoreLink}</a>.
  </p>

  <section class="site-footer">
    <h2>{copy.footerOther}</h2>
    <p>
      <a href={copy.instagramUrl} target="_blank" rel="noopener noreferrer"
        >Instagram</a
      >
    </p>
    <p>
      <a href={copy.xiaohongshuUrl} target="_blank" rel="noopener noreferrer"
        >Xiaohongshu</a
      >
    </p>
    <p>
      <a href={copy.spotifyUrl} target="_blank" rel="noopener noreferrer"
        >Spotify</a
      >
    </p>
  </section>
</BaseLayout>
