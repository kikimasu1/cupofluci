---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getEntry } from "astro:content";
import { getPosts, formatDate } from "../lib/posts";
import { copy } from "../i18n/ui";
import { path } from "../lib/path";

const posts = (await getPosts()).filter((p) => !p.data.draft).slice(0, 5);
const home = await getEntry("home", "home");
if (!home) {
  throw new Error("Missing content: src/content/home/home.md");
}
const h = home.data;
---

<BaseLayout title={h.title} description={h.description ?? h.title}>
  <p class="home-note"><em>{h.aiDisclaimer}</em></p>
  <h2>{h.me10sTitle}</h2>
  <p>{h.tagline}</p>
  {
    h.timeline.map((item) => (
      <p class="timeline-item">
        <span class="timeline-year">{item.year}</span>
        {` ${item.text}`}
      </p>
    ))
  }

  <h2>
    <a href={path("/about")}>{h.me10mTitle}</a>?
  </h2>
  <p>
    {h.me10mBefore}{" "}
    <a href={path("/about")}>{h.me10mLink}</a>
    {" "}{h.me10mAfter}
  </p>

  <h2>
    <a href={path("/now")}>{h.nowTitle}</a>?
  </h2>
  <p>
    {h.nowBefore}{" "}
    <a href={path("/now")}>{h.nowLink}</a>
    {" "}{h.nowAfter}
  </p>

  <h2>
    <a href={path("/contact")}>{h.contactTitle}</a>
  </h2>
  <p>
    {h.contactBefore}{" "}
    <a href={path("/contact")}>{h.contactLink}</a>.
  </p>

  <h2>
    {h.newestPrefix}<a href={path("/article")}>{h.newestArticles}</a>
  </h2>
  {
    posts.length ? (
      <ul class="list">
        {posts.map((post) => (
          <li>
            <span class="date">{formatDate(post.data.date)}</span>
            <a href={path(`/article/${post.id}`)}>{post.data.title}</a>
          </li>
        ))}
      </ul>
    ) : (
      <p class="muted">{copy.articleEmpty}</p>
    )
  }
  <p>
    {h.morePrefix}<a href={path("/article")}>{h.moreLink}</a>.
  </p>

  <section class="site-footer">
    <h2>{h.footerTitle}</h2>
    {
      h.platforms.map((platform) => (
        <p>
          <a href={platform.url} target="_blank" rel="noopener noreferrer">
            {platform.label}
          </a>
        </p>
      ))
    }
  </section>
</BaseLayout>
