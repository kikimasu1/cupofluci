---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { formatDate } from "../lib/posts";
import { path } from "../lib/path";
import { copy } from "../i18n/ui";
import type { SearchDoc } from "../lib/search";

const posts = await getCollection("blog", ({ data }) => !data.draft);

const docs: SearchDoc[] = posts
  .map((post) => ({
    id: post.id,
    title: post.data.title,
    description: post.data.description ?? "",
    date: formatDate(post.data.date),
    body: typeof post.body === "string" ? post.body : "",
    href: path(`/blog/${post.id}`),
  }))
  .sort((a, b) => b.date.localeCompare(a.date));
---

<BaseLayout title="Search" description="Search articles on cupofluci.">
  <h1 class="search-heading">{copy.searchTitle}</h1>

  <form class="search-form" id="search-form" role="search">
    <label class="visually-hidden" for="q">Search</label>
    <input
      id="q"
      name="q"
      type="search"
      maxlength="80"
      autocomplete="off"
      spellcheck="false"
      enterkeyhint="search"
    />
    <button type="submit">{copy.searchButton}</button>
  </form>

  <p class="muted" id="search-status" hidden></p>
  <ul class="list" id="search-results"></ul>

  <script id="search-index" type="application/json" set:html={JSON.stringify(docs)} />
</BaseLayout>

<script>
  import { searchDocs } from "../lib/search";

  type Doc = {
    id: string;
    title: string;
    description: string;
    date: string;
    body: string;
    href: string;
  };

  const indexEl = document.getElementById("search-index");
  const form = document.getElementById("search-form") as HTMLFormElement | null;
  const input = document.getElementById("q") as HTMLInputElement | null;
  const statusEl = document.getElementById("search-status");
  const listEl = document.getElementById("search-results");

  let docs: Doc[] = [];
  try {
    docs = JSON.parse(indexEl?.textContent ?? "[]") as Doc[];
  } catch {
    docs = [];
  }

  const messages = {
    hint: "Type a keyword to find articles.",
    empty: "No matching articles.",
    invalid: "Use letters, numbers, and simple punctuation only.",
  };

  function setStatus(text: string, show = true) {
    if (!statusEl) return;
    statusEl.textContent = text;
    statusEl.hidden = !show || !text;
  }

  function renderResults(results: Doc[]) {
    if (!listEl) return;
    listEl.replaceChildren();

    for (const doc of results) {
      const li = document.createElement("li");

      const date = document.createElement("span");
      date.className = "date";
      date.textContent = doc.date;

      const link = document.createElement("a");
      link.href = doc.href;
      link.textContent = doc.title;

      li.append(date, document.createTextNode(" "), link);
      listEl.append(li);
    }
  }

  function runSearch(raw: string) {
    const { cleaned, results } = searchDocs(docs, raw);

    if (!cleaned.ok) {
      renderResults([]);
      if (cleaned.reason === "empty") {
        setStatus("", false);
      } else {
        setStatus(messages.invalid, true);
      }
      return;
    }

    renderResults(results);
    setStatus(
      results.length
        ? `${results.length} result${results.length === 1 ? "" : "s"}`
        : messages.empty,
      true,
    );
  }

  const params = new URLSearchParams(window.location.search);
  const initial = params.get("q") ?? "";
  if (input && initial) {
    input.value = initial.slice(0, 80);
    runSearch(initial);
  } else {
    setStatus("", false);
  }

  form?.addEventListener("submit", (event) => {
    event.preventDefault();
    const value = input?.value ?? "";
    const url = new URL(window.location.href);
    const cleaned = value.trim().slice(0, 80);
    if (cleaned) url.searchParams.set("q", cleaned);
    else url.searchParams.delete("q");
    history.replaceState(null, "", url);
    runSearch(value);
  });
</script>
