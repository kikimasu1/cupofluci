---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getEntry } from "astro:content";
import { renderDatedPage } from "../lib/render-dated-page";

const pagePath = "src/content/pages/now.md";
const now = await getEntry("pages", "now");
if (!now) {
  throw new Error("Missing content: src/content/pages/now.md");
}

const { code } = await renderDatedPage(pagePath);
---

<BaseLayout
  title={now.data.title}
  description={now.data.description ?? now.data.title}
>
  <article class="prose">
    <h1>{now.data.title}</h1>
    <Fragment set:html={code} />
  </article>
</BaseLayout>
