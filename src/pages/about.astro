---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getEntry, render } from "astro:content";
import { fileUpdatedOn } from "../lib/file-updated";

const about = await getEntry("pages", "about");
if (!about) {
  throw new Error('Missing content: src/content/pages/about.md');
}

const { Content } = await render(about);
const updated = fileUpdatedOn("src/content/pages/about.md");
---

<BaseLayout
  title={about.data.title}
  description={about.data.description ?? about.data.title}
>
  <article class="prose">
    <h1>{about.data.title}</h1>
    <p><strong>Last Updated: {updated}</strong></p>
    <Content />
  </article>
</BaseLayout>
