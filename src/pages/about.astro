---
import { readFileSync } from "node:fs";
import { createSatteriMarkdownProcessor } from "@astrojs/markdown-satteri";
import BaseLayout from "../layouts/BaseLayout.astro";
import { getEntry } from "astro:content";
import { fileUpdatedOn } from "../lib/file-updated";

const about = await getEntry("pages", "about");
if (!about) {
  throw new Error("Missing content: src/content/pages/about.md");
}

const aboutPath = "src/content/pages/about.md";
const updated = fileUpdatedOn(aboutPath);
const raw = readFileSync(aboutPath, "utf8");
const body = raw.replace(/^---[\s\S]*?---\r?\n/, "").replace(
  "<!--LAST_UPDATED-->",
  `**Last Updated: ${updated}**`,
);

const processor = await createSatteriMarkdownProcessor();
const { code } = await processor.render(body);
---

<BaseLayout
  title={about.data.title}
  description={about.data.description ?? about.data.title}
>
  <article class="prose">
    <h1>{about.data.title}</h1>
    <Fragment set:html={code} />
  </article>
</BaseLayout>
