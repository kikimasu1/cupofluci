---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getPosts, formatDate } from "../../lib/posts";
import { copy } from "../../i18n/ui";
import { path } from "../../lib/path";

const posts = (await getPosts()).filter((p) => !p.data.draft);
const count = posts.length;
---

<BaseLayout title="Articles" description="Articles from cupofluci.">
  <h1 class="search-heading">{copy.articleTitle}</h1>

  <form class="search-form" role="search" action={path("/search")} method="get">
    <label class="visually-hidden" for="article-q">Search</label>
    <input
      id="article-q"
      name="q"
      type="search"
      maxlength="80"
      autocomplete="off"
      spellcheck="false"
      enterkeyhint="search"
    />
    <button type="submit">{copy.searchButton}</button>
  </form>

  <h2 class="articles-meta">
    {copy.articleAllMeta.replace("{count}", String(count))}
  </h2>

  {
    posts.length ? (
      <ul class="list">
        {posts.map((post) => (
          <li>
            <span class="date">{formatDate(post.data.date)}</span>
            <a href={path(`/article/${post.id}`)}>{post.data.title}</a>
          </li>
        ))}
      </ul>
    ) : (
      <p class="muted">{copy.articleEmpty}</p>
    )
  }
</BaseLayout>
